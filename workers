export default {
  async fetch(request, env) {

    const origin = request.headers.get("Origin");

    const allowedOrigins = [
      "https://s.enactusftuhanoi.id.vn",
      "http://127.0.0.1:3000",
      "http://127.0.0.1:5500"
    ];

    const corsOrigin = allowedOrigins.includes(origin)
      ? origin
      : "https://s.enactusftuhanoi.id.vn";

    if (request.method === 'OPTIONS') {
      return new Response(null, {
        headers: {
          'Access-Control-Allow-Origin': corsOrigin,
          'Access-Control-Allow-Methods': 'GET, POST, DELETE, OPTIONS, PUT',
          'Access-Control-Allow-Headers': 'Content-Type, Authorization',
          'Access-Control-Max-Age': '86400',
        },
      });
    }

    const url = new URL(request.url);
    const path = url.pathname.slice(1);
    const method = request.method;
    const hostname = url.hostname;
    const clientIP = request.headers.get('CF-Connecting-IP') || request.headers.get('X-Forwarded-For') || 'unknown';
    const cfCountry = request.headers.get('CF-IPCountry') || 'Unknown';
    const userAgent = request.headers.get('User-Agent') || '';

    function corsResponse(body, status = 200, contentType = 'application/json') {
      return new Response(body, {
        status,
        headers: {
          'Content-Type': contentType,
          'Access-Control-Allow-Origin': corsOrigin,
          'Access-Control-Allow-Methods': 'GET, POST, DELETE, OPTIONS, PUT',
          'Access-Control-Allow-Headers': 'Content-Type, Authorization',
        }
      });
    }

    // ==================== USER MANAGEMENT ====================

    async function initDefaultUser(env) {
      const usersData = await env.ADMIN_STORAGE.get("users");
      if (!usersData) {
        const defaultUser = {
          id: "1", fullname: "Super Administrator", department: "IT",
          username: "superadmin", password: btoa("superadmin"),
          role: "SuperAdmin", status: "active", must_change_password: false,
          created_by: "system", created_at: new Date().toISOString()
        };
        await env.ADMIN_STORAGE.put("users", JSON.stringify([defaultUser]));
      }
    }

    async function getUserByUsername(env, username) {
      const usersData = await env.ADMIN_STORAGE.get("users");
      const users = usersData ? JSON.parse(usersData) : [];
      return users.find(u => u.username === username);
    }

    // ĐÃ CHECK: Sắp xếp tài khoản theo thứ tự SuperAdmin -> Admin -> Member
    async function getAllUsers(env) {
      const usersData = await env.ADMIN_STORAGE.get("users");
      const users = usersData ? JSON.parse(usersData) : [];
      
      const rolePriority = { "SuperAdmin": 1, "Admin": 2, "Member": 3 };

      return users
        .map(u => { const { password, ...rest } = u; return rest; })
        .sort((a, b) => {
          const pA = rolePriority[a.role] || 99;
          const pB = rolePriority[b.role] || 99;
          return pA - pB;
        });
    }

    async function createNewUser(env, userData, createdBy) {
      const usersData = await env.ADMIN_STORAGE.get("users");
      let users = usersData ? JSON.parse(usersData) : [];
      if (users.find(u => u.username === userData.username)) throw new Error("Username already exists");
      const newUser = {
        id: Date.now().toString(), fullname: userData.fullname || "",
        department: userData.department || "", username: userData.username,
        password: btoa(userData.username), role: userData.role || "Member",
        status: "active", must_change_password: true,
        created_by: createdBy, created_at: new Date().toISOString(), updated_at: new Date().toISOString()
      };
      users.push(newUser);
      await env.ADMIN_STORAGE.put("users", JSON.stringify(users));
      const { password, ...result } = newUser;
      return result;
    }

    async function updateExistingUser(env, username, updates, updatedBy) {
      const usersData = await env.ADMIN_STORAGE.get("users");
      let users = usersData ? JSON.parse(usersData) : [];
      const index = users.findIndex(u => u.username === username);
      if (index === -1) throw new Error("User not found");
      if (users[index].role === "SuperAdmin" && updatedBy !== users[index].username) throw new Error("Cannot modify SuperAdmin");
      users[index] = {
        ...users[index],
        fullname: updates.fullname !== undefined ? updates.fullname : users[index].fullname,
        department: updates.department !== undefined ? updates.department : users[index].department,
        role: updates.role !== undefined ? updates.role : users[index].role,
        status: updates.status !== undefined ? updates.status : users[index].status,
        updated_at: new Date().toISOString(), updated_by: updatedBy
      };
      await env.ADMIN_STORAGE.put("users", JSON.stringify(users));
      const { password, ...result } = users[index];
      return result;
    }

    async function resetUserPassword(env, username, resetBy) {
      const usersData = await env.ADMIN_STORAGE.get("users");
      let users = usersData ? JSON.parse(usersData) : [];
      const index = users.findIndex(u => u.username === username);
      if (index === -1) throw new Error("User not found");
      if (users[index].role === "SuperAdmin" && resetBy !== username) throw new Error("Cannot reset SuperAdmin password");
      users[index].password = btoa(username);
      users[index].must_change_password = true;
      users[index].updated_at = new Date().toISOString();
      await env.ADMIN_STORAGE.put("users", JSON.stringify(users));
      return { success: true };
    }

    async function changeUserPassword(env, username, currentPassword, newPassword) {
      const usersData = await env.ADMIN_STORAGE.get("users");
      let users = usersData ? JSON.parse(usersData) : [];
      const index = users.findIndex(u => u.username === username);
      if (index === -1) throw new Error("User not found");
      if (users[index].password !== btoa(currentPassword)) throw new Error("Mật khẩu hiện tại không đúng");
      if (newPassword.length < 6) throw new Error("Mật khẩu mới phải có ít nhất 6 ký tự");
      if (newPassword === username) throw new Error("Mật khẩu mới không được trùng với tên đăng nhập");
      users[index].password = btoa(newPassword);
      users[index].must_change_password = false;
      users[index].updated_at = new Date().toISOString();
      await env.ADMIN_STORAGE.put("users", JSON.stringify(users));
      return { success: true };
    }

    async function deleteExistingUser(env, username) {
      const usersData = await env.ADMIN_STORAGE.get("users");
      let users = usersData ? JSON.parse(usersData) : [];
      const user = users.find(u => u.username === username);
      if (!user) throw new Error("User not found");
      if (user.role === "SuperAdmin") throw new Error("Cannot delete SuperAdmin");
      users = users.filter(u => u.username !== username);
      await env.ADMIN_STORAGE.put("users", JSON.stringify(users));
      return { success: true };
    }

    async function toggleUserStatus(env, username, toggledBy) {
      const usersData = await env.ADMIN_STORAGE.get("users");
      let users = usersData ? JSON.parse(usersData) : [];
      const index = users.findIndex(u => u.username === username);
      if (index === -1) throw new Error("User not found");
      users[index].status = users[index].status === "active" ? "disabled" : "active";
      users[index].updated_at = new Date().toISOString();
      users[index].updated_by = toggledBy;
      await env.ADMIN_STORAGE.put("users", JSON.stringify(users));
      const { password, ...result } = users[index];
      return result;
    }

    async function addUserLog(env, username, action, details, ip) {
      const logEntry = {
        id: Date.now() + '_' + Math.random().toString(36).substr(2, 6),
        time: new Date().toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh' }),
        timestamp: Date.now(), username, action, details, ip
      };
      const existing = await env.ADMIN_STORAGE.get(`user_logs_${username}`);
      let userLogs = existing ? JSON.parse(existing) : [];
      userLogs.unshift(logEntry);
      if (userLogs.length > 200) userLogs = userLogs.slice(0, 200);
      await env.ADMIN_STORAGE.put(`user_logs_${username}`, JSON.stringify(userLogs));
    }

    async function getUserLogsByUsername(env, username) {
      const existing = await env.ADMIN_STORAGE.get(`user_logs_${username}`);
      return existing ? JSON.parse(existing) : [];
    }

    async function getPublicMode(env) {
      return (await env.ADMIN_STORAGE.get("public_mode")) === "true";
    }

    async function getCurrentUser(request, env) {
      const auth = request.headers.get('Authorization');
      if (!auth || !auth.startsWith('Basic ')) return null;
      const credentials = atob(auth.split(' ')[1]);
      const colonIndex = credentials.indexOf(':');
      const username = credentials.substring(0, colonIndex);
      const password = credentials.substring(colonIndex + 1);
      const user = await getUserByUsername(env, username);
      if (user && user.password === btoa(password) && user.status === "active") {
        return {
          username: user.username, role: user.role, status: user.status,
          fullname: user.fullname, department: user.department,
          must_change_password: user.must_change_password === true
        };
      }
      return null;
    }

    await initDefaultUser(env);
    
    // ==================== SERVE UI ====================
    if (hostname === 's.enactusftuhanoi.id.vn' && path === "") {
      return fetch("https://enactusftuhanoi.github.io/s/");
    }

    // ==================== ADMIN API ====================

    if (path === "admin/current-user" && method === "GET") {
      const cu = await getCurrentUser(request, env);
      if (!cu) return corsResponse(JSON.stringify({ error: "Unauthorized" }), 401);
      return corsResponse(JSON.stringify(cu));
    }

    if (path === "admin/change-password" && method === "POST") {
      const cu = await getCurrentUser(request, env);
      if (!cu) return corsResponse(JSON.stringify({ error: "Unauthorized" }), 401);
      try {
        const body = await request.json();
        if (!body.currentPassword || !body.newPassword) return corsResponse(JSON.stringify({ error: "Thiếu thông tin" }), 400);
        await changeUserPassword(env, cu.username, body.currentPassword, body.newPassword);
        await addUserLog(env, cu.username, "change_password", {}, clientIP);
        return corsResponse(JSON.stringify({ success: true }));
      } catch (e) { return corsResponse(JSON.stringify({ error: e.message }), 400); }
    }

    if (path === "admin/users" && method === "GET") {
      const cu = await getCurrentUser(request, env);
      if (!cu || (cu.role !== "SuperAdmin" && cu.role !== "Admin")) return corsResponse(JSON.stringify({ error: "Unauthorized" }), 403);
      return corsResponse(JSON.stringify(await getAllUsers(env)));
    }

    if (path === "admin/users" && method === "POST") {
      const cu = await getCurrentUser(request, env);
      if (!cu || (cu.role !== "SuperAdmin" && cu.role !== "Admin")) return corsResponse(JSON.stringify({ error: "Unauthorized" }), 403);
      try {
        const body = await request.json();
        if (!body.username) return corsResponse(JSON.stringify({ error: "Username required" }), 400);
        if (cu.role === "Admin" && body.role === "SuperAdmin") return corsResponse(JSON.stringify({ error: "Admin cannot create SuperAdmin" }), 403);
        const newUser = await createNewUser(env, body, cu.username);
        await addUserLog(env, cu.username, "create_user", { username: body.username, role: body.role }, clientIP);
        return corsResponse(JSON.stringify(newUser));
      } catch (e) { return corsResponse(JSON.stringify({ error: e.message }), 400); }
    }

    // ==================== API BULK CREATE USERS ====================
    if (path === "admin/users/bulk" && method === "POST") {
      const cu = await getCurrentUser(request, env);
      if (!cu || (cu.role !== 'SuperAdmin' && cu.role !== 'Admin')) {
        return corsResponse(JSON.stringify({ error: "Không có quyền thực hiện hành động này." }), 403);
      }

      try {
        const body = await request.json(); // Nhận mảng [{fullname, department, username, role}]
        if (!body.users || !Array.isArray(body.users)) {
          return corsResponse(JSON.stringify({ error: "Dữ liệu không hợp lệ." }), 400);
        }

        const usersData = await env.ADMIN_STORAGE.get("users");
        let users = usersData ? JSON.parse(usersData) : [];
        
        const errors = [];
        const usersToAdd = [];

        for (const inputUser of body.users) {
          const uName = (inputUser.username || "").trim();
          const fName = (inputUser.fullname || "").trim();
          const dept = (inputUser.department || "").trim();
          const role = (inputUser.role || "Member").trim();

          if (!uName || !fName) {
            errors.push(`Bỏ qua dòng lỗi: Thiếu tên hoặc username.`);
            continue;
          }

          // Kiểm tra trùng lặp trong bộ nhớ tạm và trong DB hiện tại
          const isDuplicate = users.some(u => u.username === uName) || usersToAdd.some(u => u.username === uName);
          if (isDuplicate) {
            errors.push(`Username "${uName}" đã tồn tại trên hệ thống.`);
            continue;
          }

          usersToAdd.push({
            id: (Date.now() + Math.floor(Math.random() * 10000)).toString() + '_' + Math.random().toString(36).substr(2, 4),
            fullname: fName,
            department: dept || "BĐH",
            username: uName,
            password: btoa(uName), // Mật khẩu mặc định là mã hóa base64 của username
            role: role,
            status: "active",
            must_change_password: true, // Ép đổi mật khẩu khi đăng nhập lần đầu
            created_by: cu.username,
            created_at: new Date().toISOString(),
            updated_at: new Date().toISOString()
          });
        }

        if (usersToAdd.length > 0) {
          users = [...users, ...usersToAdd];
          await env.ADMIN_STORAGE.put("users", JSON.stringify(users));
          // Ghi nhật ký hành động (Action Log)
          await addActionLog(env, clientIP, cu.username, "BULK_CREATE_USER", { count: usersToAdd.length });
        }

        return corsResponse(JSON.stringify({
          success: true,
          message: `Đã tạo thành công ${usersToAdd.length} tài khoản.`,
          errors: errors
        }));

      } catch (e) {
        return corsResponse(JSON.stringify({ error: e.message }), 500);
      }
    }

    if (path.startsWith("admin/users/") && method === "PUT") {
      const cu = await getCurrentUser(request, env);
      if (!cu || (cu.role !== "SuperAdmin" && cu.role !== "Admin")) return corsResponse(JSON.stringify({ error: "Unauthorized" }), 403);
      const targetUsername = path.split("/")[2];
      try {
        const body = await request.json();
        if (cu.role === "Admin") {
          const target = await getUserByUsername(env, targetUsername);
          if (target && target.role === "SuperAdmin") return corsResponse(JSON.stringify({ error: "Admin cannot modify SuperAdmin" }), 403);
        }
        const updated = await updateExistingUser(env, targetUsername, body, cu.username);
        await addUserLog(env, cu.username, "update_user", { username: targetUsername }, clientIP);
        return corsResponse(JSON.stringify(updated));
      } catch (e) { return corsResponse(JSON.stringify({ error: e.message }), 400); }
    }

    if (path.startsWith("admin/users/") && method === "DELETE") {
      const cu = await getCurrentUser(request, env);
      if (!cu || cu.role !== "SuperAdmin") return corsResponse(JSON.stringify({ error: "Unauthorized" }), 403);
      const targetUsername = path.split("/")[2];
      try {
        await deleteExistingUser(env, targetUsername);
        await addUserLog(env, cu.username, "delete_user", { username: targetUsername }, clientIP);
        return corsResponse(JSON.stringify({ success: true }));
      } catch (e) { return corsResponse(JSON.stringify({ error: e.message }), 400); }
    }

    if (path.match(/admin\/users\/.+\/reset-password/) && method === "POST") {
      const cu = await getCurrentUser(request, env);
      if (!cu || cu.role !== "SuperAdmin") return corsResponse(JSON.stringify({ error: "Unauthorized" }), 403);
      const targetUsername = path.split("/")[2];
      try {
        await resetUserPassword(env, targetUsername, cu.username);
        await addUserLog(env, cu.username, "reset_password", { username: targetUsername }, clientIP);
        return corsResponse(JSON.stringify({ success: true }));
      } catch (e) { return corsResponse(JSON.stringify({ error: e.message }), 400); }
    }

    if (path.match(/admin\/users\/.+\/toggle-status/) && method === "POST") {
      const cu = await getCurrentUser(request, env);
      if (!cu || (cu.role !== "SuperAdmin" && cu.role !== "Admin")) return corsResponse(JSON.stringify({ error: "Unauthorized" }), 403);
      const targetUsername = path.split("/")[2];
      try {
        const result = await toggleUserStatus(env, targetUsername, cu.username);
        await addUserLog(env, cu.username, "toggle_status", { username: targetUsername, newStatus: result.status }, clientIP);
        return corsResponse(JSON.stringify(result));
      } catch (e) { return corsResponse(JSON.stringify({ error: e.message }), 400); }
    }

    if (path.match(/^admin\/logs\/.+/) && method === "GET") {
      const cu = await getCurrentUser(request, env);
      if (!cu || (cu.role !== "SuperAdmin" && cu.role !== "Admin")) return corsResponse(JSON.stringify({ error: "Unauthorized" }), 403);
      return corsResponse(JSON.stringify(await getUserLogsByUsername(env, path.split("/")[2])));
    }

    if (path === "admin/settings/public" && method === "GET") {
      return corsResponse(JSON.stringify({ enabled: await getPublicMode(env) }));
    }

    if (path === "admin/settings/public" && method === "POST") {
      const cu = await getCurrentUser(request, env);
      if (!cu || (cu.role !== "SuperAdmin" && cu.role !== "Admin")) return corsResponse(JSON.stringify({ error: "Unauthorized" }), 403);
      const body = await request.json();
      await env.ADMIN_STORAGE.put("public_mode", body.enabled.toString());
      await addUserLog(env, cu.username, "set_public_mode", { enabled: body.enabled }, clientIP);
      return corsResponse(JSON.stringify({ enabled: body.enabled }));
    }

    // ĐÃ FIX 1: Vá lỗ hổng chặn quyền sửa link khi owner vô chủ (undefined)
    if (path.match(/^link\/.+\/edit/) && method === "POST") {
      const cu = await getCurrentUser(request, env);
      if (!cu) return corsResponse(JSON.stringify({ error: "Unauthorized" }), 401);
      const code = path.split("/")[1];
      try {
        const body = await request.json();
        const linkOwners = JSON.parse(await env.STATS_STORAGE.get("link_owners") || "{}");
        const owner = linkOwners[code];
        
        if (cu.role !== "SuperAdmin" && cu.role !== "Admin") {
          if (!owner || owner !== cu.username) {
            return corsResponse(JSON.stringify({ error: "Không có quyền sửa link này" }), 403);
          }
        }

        const existing = await env.URL_STORAGE.get(code);
        if (!existing) return corsResponse(JSON.stringify({ error: "Link không tồn tại" }), 404);

        let linkData;
        try { linkData = JSON.parse(existing); } catch { linkData = { url: existing }; }

        if (body.url) {
          if (!body.url.startsWith("http")) return corsResponse(JSON.stringify({ error: "URL không hợp lệ" }), 400);
          linkData.url = body.url;
        }
        if (body.expiryDate !== undefined) linkData.expiry_date = body.expiryDate || null;
        if (body.password !== undefined) linkData.password = body.password || null;

        await env.URL_STORAGE.put(code, JSON.stringify(linkData));
        const linkMetaRaw = await env.ADMIN_STORAGE.get("link_meta");
        const linkMeta = linkMetaRaw ? JSON.parse(linkMetaRaw) : {};
        if (!linkMeta[code]) linkMeta[code] = {};
        linkMeta[code].expiry_date = linkData.expiry_date || null;
        linkMeta[code].has_password = !!(linkData.password);
        await env.ADMIN_STORAGE.put("link_meta", JSON.stringify(linkMeta));

        // ĐÃ FIX 2: Bọc dự phòng chuỗi rỗng để tránh crash lỗi undefined tên tài khoản
        await addActionLog(env, clientIP, cu.username || "unknown", 'edit_link', { code, url: linkData.url });
        return corsResponse(JSON.stringify({ success: true }));
      } catch (e) { return corsResponse(JSON.stringify({ error: e.message }), 400); }
    }

    if (path.match(/link\/.+\/toggle-public/) && method === "POST") {
      const cu = await getCurrentUser(request, env);
      if (!cu || (cu.role !== "Admin" && cu.role !== "SuperAdmin")) return corsResponse(JSON.stringify({ error: "Unauthorized" }), 403);
      const code = path.split("/")[1];
      try {
        const body = await request.json();
        const publicLinksRaw = await env.ADMIN_STORAGE.get("public_links");
        let publicLinks = publicLinksRaw ? JSON.parse(publicLinksRaw) : [];
        if (body.is_public && !publicLinks.includes(code)) publicLinks.push(code);
        else if (!body.is_public) publicLinks = publicLinks.filter(c => c !== code);
        await env.ADMIN_STORAGE.put("public_links", JSON.stringify(publicLinks));
        return corsResponse(JSON.stringify({ success: true, is_public: body.is_public }));
      } catch (e) { return corsResponse(JSON.stringify({ error: e.message }), 400); }
    }

    // ==================== STATIC ====================
    if (path === "favicon.ico") return fetch("https://enactusftuhanoi.github.io/s/favicon.ico");
    if (path === "icon.png") return fetch("https://enactusftuhanoi.github.io/s/icon.png");

    // ==================== ORIGINAL API ====================

    if (path === "get-name" && method === "GET") {
      const usersData = await env.LOG_STORAGE.get("users");
      const users = usersData ? JSON.parse(usersData) : {};
      return corsResponse(JSON.stringify({ name: users[clientIP]?.name || null }));
    }

    if (path === "set-name" && method === "POST") {
      try {
        const body = await request.json();
        let { name } = body;
        name = name.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
        const usersData = await env.LOG_STORAGE.get("users");
        const users = usersData ? JSON.parse(usersData) : {};
        users[clientIP] = { name, firstSeen: getToday(), lastSeen: getToday() };
        await env.LOG_STORAGE.put("users", JSON.stringify(users));
        return corsResponse(JSON.stringify({ success: true, name }));
      } catch (e) { return corsResponse(JSON.stringify({ error: e.message }), 400); }
    }

    if (path === "logs" && method === "GET") {
      const [clickLogs, actionLogs, logUsers, adminUsers] = await Promise.all([
        env.LOG_STORAGE.get("click_logs").then(d => d ? JSON.parse(d) : []),
        env.LOG_STORAGE.get("action_logs").then(d => d ? JSON.parse(d) : []),
        env.LOG_STORAGE.get("users").then(d => d ? JSON.parse(d) : {}),
        getAllUsers(env)
      ]);

      const now = new Date();
      const tzOffset = 7 * 60 * 60 * 1000;
      const todayStartTime = Math.floor((now.getTime() + tzOffset) / (24 * 60 * 60 * 1000)) * (24 * 60 * 60 * 1000) - tzOffset;

      const todayClickCount = (clickLogs || []).filter(l => (l.timestamp || 0) >= todayStartTime).length;
      const todayActionCount = (actionLogs || []).filter(l => (l.timestamp || 0) >= todayStartTime).length;
      const todayNewLinksCount = (actionLogs || []).filter(l => (l.timestamp || 0) >= todayStartTime && l.action === 'create_link').length;

      return corsResponse(JSON.stringify({ 
        clickLogs, 
        actionLogs, 
        users: logUsers, 
        adminUsersCount: adminUsers.length,
        todayStats: {
          clicks: todayClickCount,
          actions: todayActionCount,
          newLinks: todayNewLinksCount
        }
      }));
    }

    if (path === "hourly-stats" && method === "GET") {
      try {
        const now = new Date();
        const tzOffset = 7 * 60 * 60 * 1000;
        const todayStartTime = Math.floor((now.getTime() + tzOffset) / (24 * 60 * 60 * 1000)) * (24 * 60 * 60 * 1000) - tzOffset;

        const hourlyData = Array.from({ length: 24 }, (_, i) => ({ hour: i, clicks: 0 }));
        const clickLogs = await env.LOG_STORAGE.get("click_logs").then(d => d ? JSON.parse(d) : []);
        
        clickLogs.forEach(log => {
          if (log.timestamp && log.timestamp >= todayStartTime) {
            const logDate = new Date(log.timestamp + tzOffset);
            const hour = logDate.getUTCHours(); 
            if (hour >= 0 && hour <= 23) hourlyData[hour].clicks++;
          }
        });
        
        const currentHour = new Date(now.getTime() + tzOffset).getUTCHours();
        return corsResponse(JSON.stringify(hourlyData.filter(h => h.hour <= currentHour)));
      } catch {
        return corsResponse(JSON.stringify([]));
      }
    }

    if (path === "stats" && method === "GET") {
