    let show = false;
    if (!username) show = false;
    else if (isAdminOrSuper) show = true;
    else if (owner === username) show = true;
    else if (publicMode && isPublic) show = true;

    if (!show) continue;
    let parsed;
    try { parsed = JSON.parse(rawData); } catch { parsed = { url: rawData }; }

    const meta = linkMeta[code] || {};
    const expiryDate = parsed.expiry_date || meta.expiry_date || null;
    const hasPassword = !!(parsed.password || meta.has_password);
    const createdAt = parsed.created_at || meta.created_at || new Date().toISOString();
    links.push({
      code,
      original_url: parsed.url || rawData,
      clicks: topLinks[code] || 0,
      created_at: createdAt,
      created_by: owner,
      is_public: isPublic,
      expiry_date: expiryDate,
      has_password: hasPassword,
    });
  }
  return links;
}

async function createShortUrl(env, originalUrl, customCode = "", userName = "", expiryDate = null, password = null) {
  if (!originalUrl || !originalUrl.startsWith("http")) throw new Error("URL không hợp lệ");
  let code = customCode || generateRandomCode();
  const existing = await env.URL_STORAGE.get(code);
  if (existing) throw new Error("Code đã tồn tại");
  const linkData = { url: originalUrl, created_at: new Date().toISOString()};
  if (expiryDate) linkData.expiry_date = expiryDate;
  if (password) linkData.password = password;
  await env.URL_STORAGE.put(code, JSON.stringify(linkData));

  const linkListRaw = await env.STATS_STORAGE.get("link_list");
  const linkList = linkListRaw ? JSON.parse(linkListRaw) : [];
  if (!linkList.includes(code)) { 
    linkList.push(code);
    await env.STATS_STORAGE.put("link_list", JSON.stringify(linkList)); 
  }

  const linkOwnersRaw = await env.STATS_STORAGE.get("link_owners");
  const linkOwners = linkOwnersRaw ? JSON.parse(linkOwnersRaw) : {};
  linkOwners[code] = userName || "unknown";
  await env.STATS_STORAGE.put("link_owners", JSON.stringify(linkOwners));

  const statsRaw = await env.STATS_STORAGE.get("global");
  const stats = statsRaw ? JSON.parse(statsRaw) : {};
  stats.totalLinks = linkList.length;
  await env.STATS_STORAGE.put("global", JSON.stringify(stats));

  const linkMetaRaw = await env.ADMIN_STORAGE.get("link_meta");
  const linkMeta = linkMetaRaw ? JSON.parse(linkMetaRaw) : {};
  linkMeta[code] = { created_at: new Date().toISOString(), expiry_date: expiryDate || null, has_password: !!password };
  await env.ADMIN_STORAGE.put("link_meta", JSON.stringify(linkMeta));

  return { success: true, shortUrl: `https://s.enactusftuhanoi.id.vn/${code}`, code };
}

async function deleteLink(env, code) {
  await env.URL_STORAGE.delete(code);
  const [linkListRaw, linkOwnersRaw, statsRaw, linkMetaRaw] = await Promise.all([
    env.STATS_STORAGE.get("link_list"),
    env.STATS_STORAGE.get("link_owners"),
    env.STATS_STORAGE.get("global"),
    env.ADMIN_STORAGE.get("link_meta")
  ]);
  const linkList = (linkListRaw ? JSON.parse(linkListRaw) : []).filter(c => c !== code);
  await env.STATS_STORAGE.put("link_list", JSON.stringify(linkList));
  const linkOwners = linkOwnersRaw ? JSON.parse(linkOwnersRaw) : {};
  delete linkOwners[code];
  await env.STATS_STORAGE.put("link_owners", JSON.stringify(linkOwners));
  const stats = statsRaw ? JSON.parse(statsRaw) : {};
  if (stats.topLinks?.[code]) delete stats.topLinks[code];
  stats.totalLinks = linkList.length;
  await env.STATS_STORAGE.put("global", JSON.stringify(stats));
  const linkMeta = linkMetaRaw ? JSON.parse(linkMetaRaw) : {};
  delete linkMeta[code];
  await env.ADMIN_STORAGE.put("link_meta", JSON.stringify(linkMeta));
}

async function updateStatsWithUTM(env, code, utm) {
  const statsRaw = await env.STATS_STORAGE.get("global");
  let stats = statsRaw ? JSON.parse(statsRaw) : { totalClick: 0, todayClick: 0, lastDay: getToday(), topLinks: {} };
  const today = getToday();
  if (stats.lastDay !== today) { stats.todayClick = 0; stats.lastDay = today; }
  stats.totalClick = (stats.totalClick || 0) + 1;
  stats.todayClick = (stats.todayClick || 0) + 1;
  stats.topLinks[code] = (stats.topLinks[code] || 0) + 1;
  await env.STATS_STORAGE.put("global", JSON.stringify(stats));
  
  const dayRaw = await env.STATS_STORAGE.get(`day_${today}`);
  const dayStats = dayRaw ? JSON.parse(dayRaw) : { clicks: 0 };
  dayStats.clicks++;
  await env.STATS_STORAGE.put(`day_${today}`, JSON.stringify(dayStats));
  
  const utmRaw = await env.STATS_STORAGE.get("link_utm_stats");
  const linkUTMStats = utmRaw ? JSON.parse(utmRaw) : {};
  if (!linkUTMStats[code]) linkUTMStats[code] = {};
  linkUTMStats[code][utm] = (linkUTMStats[code][utm] || 0) + 1;
  await env.STATS_STORAGE.put("link_utm_stats", JSON.stringify(linkUTMStats));
}

async function getLinkUTMStats(env) {
  const d = await env.STATS_STORAGE.get("link_utm_stats");
  return d ? JSON.parse(d) : {};
}

// ĐÃ FIX 3: Bọc Try/Catch cẩn thận tránh sập toàn bộ cụm biểu đồ 7 ngày
async function getDailyClicks(env) {
  const today = new Date();
  const promises = [];
  const dates = [];
  for (let i = 6; i >= 0; i--) {
    const date = new Date(today);
    date.setDate(today.getDate() - i);
    const dateStr = date.toLocaleDateString('en-CA', { timeZone: 'Asia/Ho_Chi_Minh' });
    dates.push(dateStr);
    promises.push(env.STATS_STORAGE.get(`day_${dateStr}`));
  }
  const results = await Promise.all(promises);
  return dates.map((date, i) => {
    let dayClicks = 0;
    if (results[i]) {
      try {
        const parsed = JSON.parse(results[i]);
        dayClicks = parsed.clicks || 0;
      } catch (e) {
        dayClicks = 0;
      }
    }
    return { date, clicks: dayClicks };
  });
}

async function addClickLog(env, ip, userName, code, utm, target, country = 'Unknown', ua = '') {
  const logEntry = {
    id: Date.now() + '_' + Math.random().toString(36).substr(2, 6),
    time: new Date().toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh' }),
    timestamp: Date.now(),
    ip, 
    user: userName || 'unknown', 
    code,
    utm: utm === 'direct' ? 'Trực tiếp' : utm,
    target, 
    country, 
    ua
  };
  const existing = await env.LOG_STORAGE.get("click_logs");
  let clickLogs = existing ? JSON.parse(existing) : [];
  clickLogs.unshift(logEntry);
  if (clickLogs.length > 2000) clickLogs = clickLogs.slice(0, 2000);
  await env.LOG_STORAGE.put("click_logs", JSON.stringify(clickLogs));
}

